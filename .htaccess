# ============================================================
# LITESPEED — CACHE & PERFORMANCE
# ============================================================

# ════════════════════════════════════════════════════════════
# LSCache (LiteSpeed) — equivalente ao plugin do WordPress
# Documentacao: https://docs.litespeedtech.com/lscache/lscwp/
# ════════════════════════════════════════════════════════════
<IfModule LiteSpeed>
  # Habilita o modulo LSCache
  CacheLookup public on

  # ── HTML: cache publico por 1 dia (site estatico, conteudo raro muda)
  RewriteEngine On
  RewriteRule .* - [E=Cache-Control:public,max-age=86400]

  # ── Nao cacheia se houver query string (?utm_source=, ?preview, etc)
  RewriteCond %{QUERY_STRING} .+
  RewriteRule .* - [E=Cache-Control:no-cache]

  # ── Nao cacheia metodos POST nem area logada (se existir no futuro)
  RewriteCond %{REQUEST_METHOD} !^GET$ [OR]
  RewriteCond %{HTTP_COOKIE} (wordpress_logged_in|admin_session) [NC]
  RewriteRule .* - [E=Cache-Control:no-cache]

  # ── Vary: separa cache mobile/desktop (se quiser usar)
  # RewriteCond %{HTTP_USER_AGENT} (mobile|android|iphone) [NC]
  # RewriteRule .* - [E=Cache-Vary:ismobile]
</IfModule>

# Fallback Apache (mod_expires) — usado se LSCache não estiver ativo
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html             "access plus 1 hour"
  ExpiresByType text/css              "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg            "access plus 1 year"
  ExpiresByType image/png             "access plus 1 year"
  ExpiresByType image/webp            "access plus 1 year"
  ExpiresByType image/svg+xml         "access plus 1 year"
  ExpiresByType image/x-icon          "access plus 1 year"
  ExpiresByType application/pdf       "access plus 1 month"
  ExpiresByType font/woff2            "access plus 1 year"
</IfModule>

# Compressão — Brotli (LiteSpeed nativo) com fallback GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# Headers de cache no browser
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|svg|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
# SEGURANÇA
# ============================================================

# Bloqueia acesso a arquivos sensíveis
<FilesMatch "(^\.|\.env|\.git|README\.md|\.gitignore|\.md|deploy\.sh)">
  Require all denied
</FilesMatch>

# Bloqueia listagem de diretórios
Options -Indexes

# Headers de segurança
<IfModule mod_headers.c>
  Header always unset X-Powered-By
  Header always unset Server
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — só ative depois que SSL estiver 100% funcionando
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ============================================================
# REWRITES — URLs LIMPAS & HTTPS
# ============================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Força HTTPS (descomente após instalar SSL)
  # RewriteCond %{HTTPS} !=on
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Força não-www (ou inverta para www)
  # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  # RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Esconde a pasta /pages/ na URL:
  # Se acessarem /pages/about (ou /pages/about.html), redireciona pra /about
  RewriteCond %{THE_REQUEST} \s/+pages/([^\s?]+?)(?:\.html)?[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Se acessarem /about.html, redireciona pra /about (URL limpa)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # /about → tenta /about.html (raiz)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ /$1.html [L]

  # /about → tenta /pages/about.html (servido internamente, URL continua /about)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/pages/$1.html -f
  RewriteRule ^(.+?)/?$ /pages/$1.html [L]
</IfModule>

# Páginas de erro
ErrorDocument 404 /404.html
ErrorDocument 403 /404.html
